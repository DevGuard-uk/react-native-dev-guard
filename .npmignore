**/.gradle/
android/build/
android/local.properties
android/.settings/

# iOS build artifacts
ios/build/
ios/Pods/
**/*.xcworkspace
**/*.xcuserdata

# General build / IDE noise
**/build/
**/.idea/
**/*.iml
**/DerivedData/
**/*.log
.DS_Store
